# Google Sheets — no longer used, replaced by Supabase + Nodemailer
# GOOGLE_SHEETS_URL=

# Gmail (for Nodemailer)
# Use a Gmail App Password — NOT your login password
# Enable at: myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Calendly Integration
# Get your Calendly scheduling link from: calendly.com/event_types
# Example: https://calendly.com/your-username/discovery-call
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/30min

# Firebase (client-side — safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role — SERVER SIDE ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# AI Marketing Audit
NEXT_PUBLIC_BASE_URL=https://socioryx.com

# OpenRouter AI — for audit analysis
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Sentry (error tracking)
# Get your DSN at: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# Client-side (safe to expose):
NEXT_PUBLIC_SENTRY_DSN=
# Server-side:
SENTRY_ORG=
SENTRY_PROJECT=
